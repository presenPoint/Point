# 이 파일을 복사해 `.env.local` 로 저장한 뒤 값을 채우세요.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 로컬 전용: 브라우저에서 OpenAI 직접 호출(대부분 CORS로 막힘). 서버 프록시를 쓰면 비워도 됨.
VITE_OPENAI_API_KEY=

# 로컬에서만: vercel dev 로 /api 를 띄울 때 1 로 두면 프록시 경로 사용.
# 프로덕션 빌드(npm run build)는 기본으로 /api/openai 를 쓰므로 이 줄은 선택입니다.
# VITE_OPENAI_SERVER_PROXY=1

# Vercel Blob — /api/save-transcript 가 전사 텍스트를 저장할 때 필요
# BLOB_READ_WRITE_TOKEN=

# Google 로그인 후 돌아올 주소 (비우면 자동: 현재 origin + "/")
# 로컬에서 Vercel로 튀면 Supabase 대시보드 Redirect URLs에 아래와 동일한 줄을 추가하세요.
# VITE_OAUTH_REDIRECT_URL=http://localhost:5173/
